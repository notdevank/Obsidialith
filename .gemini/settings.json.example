{
  "general": {
    "defaultApprovalMode": "auto_edit"
  },
  "hooksConfig": {
    "disabled": [
      "omg-quota-watch-after-agent"
    ]
  },
  "mcpServers": {
    "gemini-obsidian": {
      "command": "node",
      "args": [
        "path/to/gemini-obsidian/dist/index.js"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "YOUR_OBSIDIAN_REST_API_KEY"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY"
      }
    },
    "github-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT"
      }
    },
    "google-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-workspace"
      ]
    },
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp",
        "--headless"
      ]
    },
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_CONTEXT7_API_KEY"
      }
    },
    "alphavantage": {
      "url": "https://mcp.alphavantage.co/mcp?apikey=YOUR_ALPHAVANTAGE_KEY",
      "type": "http"
    },
    "langsearch": {
      "command": "npx",
      "args": [
        "-y",
        "langsearch-mcp"
      ],
      "env": {
        "LANGSEARCH_API_KEY": "YOUR_LANGSEARCH_API_KEY"
      }
    },
    "rag-anything": {
      "command": "npx",
      "args": [
        "-y",
        "rag-anything-mcp"
      ]
    },
    "genkit": {
      "command": "npx",
      "args": [
        "-y",
        "genkit-mcp"
      ]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "supabase-mcp"
      ],
      "env": {
        "SUPABASE_URL": "YOUR_SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY": "YOUR_SUPABASE_KEY"
      }
    },
    "stitch": {
      "command": "npx",
      "args": [
        "-y",
        "stitch-mcp"
      ],
      "env": {
        "STITCH_API_KEY": "YOUR_STITCH_API_KEY"
      }
    },
    "design-skills": {
      "command": "npx",
      "args": [
        "-y",
        "design-skills-mcp"
      ]
    },
    "growth-skills": {
      "command": "npx",
      "args": [
        "-y",
        "growth-skills-mcp"
      ]
    },
    "personal-skills": {
      "command": "npx",
      "args": [
        "-y",
        "personal-skills-mcp"
      ]
    },
    "twitter": {
      "command": "npx",
      "args": [
        "-y",
        "twitter-automation-mcp"
      ],
      "env": {
        "TWITTER_API_KEY": "YOUR_TWITTER_KEY"
      }
    },
    "file-tools": {
      "command": "npx",
      "args": [
        "-y",
        "file-tools-mcp"
      ]
    }
  }
}
